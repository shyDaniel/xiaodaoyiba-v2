{
  "$comment": "Repo-local MCP overrides. Both Chromium-based MCPs are pinned to the local Playwright-managed Chromium because the system has no /opt/google/chrome install. LD_LIBRARY_PATH provides the X11/atk/cups shared libs that ms-playwright/chromium-1217 needs but the host's default lib path lacks. See WORKLOG.md S-246 for the full repro.",
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--isolated",
        "--executable-path",
        "/home/hanyu/.cache/ms-playwright/chromium-1217/chrome-linux64/chrome",
        "--no-sandbox",
        "--viewport-size",
        "1280,800"
      ],
      "env": {
        "LD_LIBRARY_PATH": "/tmp/libs/extracted/usr/lib/x86_64-linux-gnu",
        "PLAYWRIGHT_BROWSERS_PATH": "/home/hanyu/.cache/ms-playwright"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--isolated",
        "--executablePath",
        "/home/hanyu/.cache/ms-playwright/chromium-1217/chrome-linux64/chrome",
        "--chromeArg=--no-sandbox",
        "--chromeArg=--disable-setuid-sandbox",
        "--chromeArg=--disable-dev-shm-usage",
        "--viewport",
        "1280x800",
        "--no-usage-statistics"
      ],
      "env": {
        "LD_LIBRARY_PATH": "/tmp/libs/extracted/usr/lib/x86_64-linux-gnu"
      }
    }
  }
}
